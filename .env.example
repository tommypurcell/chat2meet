# Copy to `.env` and fill in. Never commit `.env`.

# --- Option A: path to the downloaded service account JSON (works with multiline private_key)
FIREBASE_SERVICE_ACCOUNT_FILE=./firebase-service-account.json
# Or the standard GCP name:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# --- Option B: no key file — use Application Default Credentials (after `gcloud auth application-default login`)
# Leave the vars above unset.

# --- Not recommended: single-line or base64 JSON only (multiline JSON in .env will fail)
# FIREBASE_SERVICE_ACCOUNT=

# --- Firebase Client SDK (public config for browser)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Google Calendar OAuth (for calendar integration)
# Get these from Google Cloud Console > APIs & Services > Credentials
# Create OAuth 2.0 Client ID (Web application type)
# Add authorized redirect URI: http://localhost:3000/auth (dev)
# and https://yourdomain.com/auth (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth redirect URI (where Google sends users after consent)
OAUTH_REDIRECT_URI=http://localhost:3000/auth

# Encryption key for storing calendar tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))")
ENCRYPTION_KEY=

# Google AI (Gemini) — chat agent in /api/chat
GEMINI_API_KEY=
# Optional — default is gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite
