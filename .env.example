# Copy to `.env` and fill in. Never commit `.env`.

# --- Option A: path to the downloaded service account JSON (works with multiline private_key)
FIREBASE_SERVICE_ACCOUNT_FILE=./firebase-service-account.json
# Or the standard GCP name:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# --- Option B: no key file — use Application Default Credentials (after `gcloud auth application-default login`)
# Leave the vars above unset.

# --- Not recommended: single-line or base64 JSON only (multiline JSON in .env will fail)
# FIREBASE_SERVICE_ACCOUNT=
